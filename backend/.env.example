# Copy to .env and fill in values (never commit .env)

NODE_ENV=production
PORT=5000

# Required
MONGODB_URI=mongodb+srv://user:pass@cluster/crm
JWT_SECRET=use-a-long-random-string
JWT_EXPIRE=7d

# CORS: your exact frontend origin(s), comma-separated if multiple
CORS_ORIGIN=https://your-app.onrender.com

# Used in invitation emails and OAuth redirects
FRONTEND_URL=https://your-app.onrender.com

# Email (required by validateEmailConfig at startup — see your email provider)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=

# Google OAuth (if used)
# GOOGLE_CLIENT_ID=
